{
  "brand": {
    "name": "LexControl",
    "description": "Sistema operativo de vigilancia judicial. Operational control center for judicial monitoring."
  },
  "color": {
    "brand": {
      "default": "#142A54",
      "hover": "#1B376A",
      "active": "#0D1F40",
      "soft": "#E9EEF7",
      "border": "#B7C4DB"
    },
    "info": {
      "default": "#1F5FBF",
      "hover": "#174F9F",
      "soft": "#EAF2FF",
      "border": "#B7D2FF",
      "text": "#174F9F"
    },
    "success": {
      "default": "#34B048",
      "hover": "#278C38",
      "soft": "#EAF8ED",
      "border": "#AEE2B8",
      "text": "#1F6D2D"
    },
    "warning": {
      "default": "#F89820",
      "hover": "#D47B0A",
      "soft": "#FFF4DF",
      "border": "#FFD08A",
      "text": "#8A4F00"
    },
    "error": {
      "default": "#EC3A40",
      "hover": "#C92D33",
      "soft": "#FEEEEE",
      "border": "#F5B9BC",
      "text": "#9F252A"
    },
    "neutral": {
      "text": "#1F2933",
      "textMuted": "#5F6B7A",
      "textSubtle": "#7B8794",
      "border": "#D8DEE8",
      "borderStrong": "#B7C1D1",
      "background": "#F7F9FC",
      "surface": "#FFFFFF",
      "surfaceSubtle": "#F2F5F9",
      "surfaceRaised": "#FFFFFF",
      "disabled": "#E6EBF2",
      "disabledText": "#9AA6B2"
    }
  },
  "semanticColor": {
    "stateSuccess": "{color.success.default}",
    "stateWarning": "{color.warning.default}",
    "stateError": "{color.error.default}",
    "stateInfo": "{color.info.default}",
    "stateNeutral": "{color.neutral.textMuted}",
    "appBackground": "{color.neutral.background}",
    "panelSurface": "{color.neutral.surface}",
    "textPrimary": "{color.neutral.text}",
    "textSecondary": "{color.neutral.textMuted}",
    "borderDefault": "{color.neutral.border}"
  },
  "typography": {
    "fontFamily": {
      "sans": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "data": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
    },
    "scale": {
      "h1": {
        "fontSize": "28px",
        "lineHeight": "36px",
        "fontWeight": 700
      },
      "h2": {
        "fontSize": "22px",
        "lineHeight": "30px",
        "fontWeight": 650
      },
      "h3": {
        "fontSize": "18px",
        "lineHeight": "26px",
        "fontWeight": 650
      },
      "body": {
        "fontSize": "14px",
        "lineHeight": "22px",
        "fontWeight": 400
      },
      "bodyStrong": {
        "fontSize": "14px",
        "lineHeight": "22px",
        "fontWeight": 600
      },
      "small": {
        "fontSize": "12px",
        "lineHeight": "18px",
        "fontWeight": 500
      },
      "data": {
        "fontSize": "13px",
        "lineHeight": "20px",
        "fontWeight": 500
      },
      "label": {
        "fontSize": "12px",
        "lineHeight": "16px",
        "fontWeight": 650
      }
    }
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "6": "24px",
    "8": "32px",
    "12": "48px",
    "16": "64px"
  },
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "16px"
  },
  "shadow": {
    "xs": "0 1px 2px rgb(15 23 42 / 0.06)",
    "sm": "0 4px 12px rgb(15 23 42 / 0.08)",
    "md": "0 12px 32px rgb(15 23 42 / 0.12)"
  },
  "component": {
    "button": {
      "height": "36px",
      "paddingX": "14px",
      "paddingY": "8px",
      "radius": "{radius.md}",
      "fontSize": "{typography.scale.body.fontSize}",
      "fontWeight": 600
    },
    "badge": {
      "height": "24px",
      "paddingX": "8px",
      "paddingY": "3px",
      "radius": "999px",
      "fontSize": "{typography.scale.label.fontSize}",
      "fontWeight": 650
    },
    "table": {
      "headerHeight": "40px",
      "rowMinHeight": "52px",
      "cellPaddingX": "16px",
      "cellPaddingY": "12px",
      "fontSize": "{typography.scale.data.fontSize}",
      "stateAccentWidth": "3px"
    },
    "panel": {
      "paddingCompact": "16px",
      "paddingDefault": "24px",
      "radius": "{radius.lg}",
      "border": "1px solid {color.neutral.border}",
      "background": "{color.neutral.surface}"
    },
    "filter": {
      "height": "36px",
      "radius": "{radius.md}",
      "paddingX": "12px",
      "fontSize": "{typography.scale.body.fontSize}"
    },
    "layout": {
      "sidebarWidth": "248px",
      "sidebarCollapsedWidth": "72px",
      "topbarHeight": "64px",
      "rightPanelMinWidth": "360px",
      "rightPanelMaxWidth": "420px",
      "mainGutter": "{spacing.6}"
    }
  },
  "copy": {
    "successNoChange": "Sin cambios desde última consulta",
    "infoNewMovement": "Nuevo movimiento detectado",
    "errorSourceFailed": "No se pudo consultar la fuente",
    "warningReviewNeeded": "Requiere revisión",
    "successQueryCompleted": "Consulta completada",
    "warningSourceDelayed": "Fuente intermitente",
    "metaLastSuccessfulQuery": "Última consulta exitosa"
  }
}
